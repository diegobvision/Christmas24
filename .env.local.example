# Shopify Storefront API credentials
# See SHOPIFY_SETUP.md for instructions on how to obtain these values
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Comma-separated list of collection handles to show in the top navigation
# These must match the handles of your collections in Shopify admin
NEXT_PUBLIC_NAV_COLLECTIONS=gifts,decorations,toys,stocking-fillers
